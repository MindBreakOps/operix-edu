create table public.workspaces (
  id uuid not null default gen_random_uuid (),
  name text not null,
  domain text not null,
  subscription_status text null default 'active'::text,
  logo_url text null,
  theme_colors jsonb null default '{"primary": "#1e7a50", "secondary": "#9a7230"}'::jsonb,
  created_at timestamp with time zone null default timezone ('utc'::text, now()),
  binabbas_active boolean null default false,
  operix_edu_active boolean null default false,
  sub_start_date date null,
  sub_end_date date null,
  sub_status text null default 'active'::text,
  constraint workspaces_pkey primary key (id),
  constraint workspaces_domain_key unique (domain)
) TABLESPACE pg_default;

create trigger update_sub_status_trigger BEFORE
update on workspaces for EACH row
execute FUNCTION check_subscription_status ();

-- 1. الفصول الدراسية والأعوام (لأن المدارس تعتمد على
 الفصول الأول، الثاني، الخ)
CREATE TABLE public.academic_terms_edu (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  workspace_id uuid NOT NULL,
  year_name text NOT NULL, -- مثال: 1445-1446 أو 2025-2026
  term_name text NOT NULL, -- مثال: الفصل الدراسي الأول
  is_active boolean DEFAULT false,
  CONSTRAINT terms_edu_pkey PRIMARY KEY (id)
);

-- 2. جدول الطلاب المتوافق مع التعليم العام
CREATE TABLE public.students_edu (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  workspace_id uuid NOT NULL,
  full_name text NOT NULL,
  national_id text NULL,
  stage text NOT NULL, -- ابتدائي، متوسط، ثانوي
  grade_level text NOT NULL, -- الصف الأول، الصف الثاني، الخ
  section text NULL, -- الشعبة: أ، ب، ج
  enrollment_date date DEFAULT CURRENT_DATE,
  CONSTRAINT students_edu_pkey PRIMARY KEY (id)
);

-- 3. المواد الدراسية ودرجات النجاح
CREATE TABLE public.subjects_edu (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  workspace_id uuid NOT NULL,
  name text NOT NULL, -- رياضيات، لغة عربية، فيزياء
  stage text NOT NULL, -- لتحديد أن هذه المادة تدرس في المتوسط مثلاً
  total_mark integer DEFAULT 100,
  passing_mark integer DEFAULT 50,
  CONSTRAINT subjects_edu_pkey PRIMARY KEY (id)
);

-- 4. ربط المعلمين (من جدول profiles) بالمواد والفصول
CREATE TABLE public.teacher_assignments_edu (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  workspace_id uuid NOT NULL,
  teacher_id uuid NOT NULL REFERENCES public.profiles(id) ON DELETE CASCADE,
  subject_id uuid NOT NULL REFERENCES public.subjects_edu(id) ON DELETE CASCADE,
  grade_level text NOT NULL,
  section text NOT NULL,
  CONSTRAINT teacher_assignments_edu_pkey PRIMARY KEY (id)
);

-- 5. جدول رصد الدرجات والشهادات المدرسية
CREATE TABLE public.results_edu (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  workspace_id uuid NOT NULL,
  student_id uuid NOT NULL REFERENCES public.students_edu(id) ON DELETE CASCADE,
  subject_id uuid NOT NULL REFERENCES public.subjects_edu(id) ON DELETE CASCADE,
  term_id uuid NOT NULL REFERENCES public.academic_terms_edu(id) ON DELETE CASCADE,
  marks_obtained numeric DEFAULT 0,
  notes text NULL,
  created_at timestamp with time zone DEFAULT now(),
  CONSTRAINT results_edu_pkey PRIMARY KEY (id),
  CONSTRAINT unique_student_subject_term UNIQUE (student_id, subject_id, term_id)
);

-- تفعيل الـ RLS لجميع الجداول لحماية مساحات العمل
ALTER TABLE public.academic_terms_edu ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.students_edu ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.subjects_edu ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.teacher_assignments_edu ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.results_edu ENABLE ROW LEVEL SECURITY;

