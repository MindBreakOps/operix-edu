-- 1. جدول أولياء الأمور (يُربط بحسابات profiles إذا أردنا إعطاءهم وصول للنظام)
CREATE TABLE public.guardians_edu (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  workspace_id uuid NOT NULL,
  full_name text NOT NULL,
  phone text NOT NULL,
  national_id text NULL,
  relation text DEFAULT 'أب', -- أب، أم، أخ، إلخ
  CONSTRAINT guardians_edu_pkey PRIMARY KEY (id)
);

-- جدول الربط: لأن الولي الواحد قد يكون لديه أكثر من طالب
CREATE TABLE public.student_guardians_edu (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  workspace_id uuid NOT NULL,
  student_id uuid NOT NULL REFERENCES public.students_edu(id) ON DELETE CASCADE,
  guardian_id uuid NOT NULL REFERENCES public.guardians_edu(id) ON DELETE CASCADE,
  CONSTRAINT student_guardians_edu_pkey PRIMARY KEY (id),
  CONSTRAINT unique_student_guardian UNIQUE (student_id, guardian_id)
);

-- 2. جدول الحضور والغياب اليومي للمدارس
CREATE TABLE public.attendance_edu (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  workspace_id uuid NOT NULL,
  student_id uuid NOT NULL REFERENCES public.students_edu(id) ON DELETE CASCADE,
  term_id uuid NOT NULL REFERENCES public.academic_terms_edu(id) ON DELETE CASCADE,
  date date NOT NULL DEFAULT CURRENT_DATE,
  status text NOT NULL, -- 'حاضر', 'غائب', 'متأخر', 'بعذر'
  notes text NULL,
  CONSTRAINT attendance_edu_pkey PRIMARY KEY (id),
  CONSTRAINT unique_daily_attendance UNIQUE (student_id, date)
);

-- 3. الجدول المدرسي (الحصص)
CREATE TABLE public.timetable_edu (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  workspace_id uuid NOT NULL,
  term_id uuid NOT NULL REFERENCES public.academic_terms_edu(id) ON DELETE CASCADE,
  teacher_id uuid NOT NULL REFERENCES public.profiles(id) ON DELETE CASCADE,
  subject_id uuid NOT NULL REFERENCES public.subjects_edu(id) ON DELETE CASCADE,
  grade_level text NOT NULL, -- الصف (مثال: الأول الثانوي)
  section text NOT NULL, -- الشعبة (مثال: أ)
  day_of_week integer NOT NULL, -- 0=الأحد, 1=الإثنين...
  period_number integer NOT NULL, -- الحصة الأولى، الثانية...
  CONSTRAINT timetable_edu_pkey PRIMARY KEY (id),
  CONSTRAINT unique_teacher_time UNIQUE (workspace_id, term_id, teacher_id, day_of_week, period_number) -- لمنع تعارض حصص المعلم
);

-- تفعيل الحماية
ALTER TABLE public.guardians_edu ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.student_guardians_edu ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.attendance_edu ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.timetable_edu ENABLE ROW LEVEL SECURITY;

CREATE TABLE public.behavior_edu (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  workspace_id uuid NOT NULL,
  student_id uuid NOT NULL REFERENCES public.students_edu(id) ON DELETE CASCADE,
  record_type text NOT NULL, -- 'مخالفة' أو 'تميز'
  points integer DEFAULT 0, -- خصم أو إضافة نقاط
  description text NOT NULL,
  date date NOT NULL DEFAULT CURRENT_DATE,
  CONSTRAINT behavior_edu_pkey PRIMARY KEY (id)
);

ALTER TABLE public.behavior_edu ENABLE ROW LEVEL SECURITY;



CREATE TABLE public.assignments_edu (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  workspace_id uuid NOT NULL,
  title text NOT NULL,
  description text NULL,
  subject_id uuid NOT NULL REFERENCES public.subjects_edu(id) ON DELETE CASCADE,
  teacher_id uuid NOT NULL REFERENCES public.profiles(id) ON DELETE CASCADE,
  grade_level text NOT NULL,
  due_date date NOT NULL,
  full_mark integer DEFAULT 10,
  created_at timestamp with time zone DEFAULT now(),
  CONSTRAINT assignments_edu_pkey PRIMARY KEY (id)
);
ALTER TABLE public.assignments_edu ENABLE ROW LEVEL SECURITY;


CREATE TABLE public.fees_edu (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  workspace_id uuid NOT NULL,
  student_id uuid NOT NULL REFERENCES public.students_edu(id) ON DELETE CASCADE,
  amount numeric NOT NULL DEFAULT 0,
  description text NOT NULL, -- مثال: رسوم الفصل الدراسي الأول، رسوم حافلة
  status text DEFAULT 'غير مدفوع', -- 'مدفوع', 'غير مدفوع', 'متأخر'
  due_date date NOT NULL,
  created_at timestamp with time zone DEFAULT now(),
  CONSTRAINT fees_edu_pkey PRIMARY KEY (id)
);

ALTER TABLE public.fees_edu ENABLE ROW LEVEL SECURITY;